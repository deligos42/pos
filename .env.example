# Local MySQL settings
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=pos_system

# Mail settings for password resets
# Prefer Brevo API keys over SMTP. Remove legacy SMTP vars from Railway if using Brevo API.
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_ADDRESS=no-reply@example.com
BREVO_FROM_NAME="POS System"
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="POS System"
MAIL_DEBUG=false

# Resend HTTP API (preferred in environments that block SMTP)
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM_ADDRESS=no-reply@your-verified-domain.com
# RESEND_FROM_NAME="POS System"

# Railway or production MySQL URL support (optional)
# DATABASE_URL=mysql://root:password@host:port/dbname
# MYSQL_URL=mysql://root:password@host:port/dbname
